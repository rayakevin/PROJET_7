# Configuration minimale locale.
# Les autres paramètres ont déjà des valeurs par défaut dans app/config.py.

MISTRAL_API_KEY=your_mistral_api_key

# Optionnel : protège /rebuild si l'API est exposée hors usage local.
# API_REBUILD_TOKEN=change_me

# Par défaut, le projet utilise Ollama en local.
# Mistral sert de secours pour la génération si LLM_PROVIDER=auto et si la clé
# ci-dessus est renseignée.

# Optionnel : exemples d'overrides ponctuels.
# APP_PORT=8000
# EVENTS_LOCATION=Paris
# LLM_PROVIDER=auto
# EMBEDDING_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_CHAT_MODEL=qwen2.5:7b
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_MIN_TOKENS=600
# OLLAMA_NUM_CTX=8192
# RAGAS_LLM_PROVIDER=ollama
# RAGAS_LLM_MODEL=qwen3:30b
# RAGAS_EMBEDDING_PROVIDER=ollama
# RAGAS_TIMEOUT_SECONDS=600
# RAGAS_MAX_WORKERS=1
# TOP_K=3
# RETRIEVAL_MAX_SCORE=0.45
# LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=600
# PROMPT_LOGS_DIR=./data/prompt_logs
# INTERACTION_DB_PATH=./data/interactions/interactions.db
