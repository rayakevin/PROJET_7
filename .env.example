# Configuration minimale locale.
# Les autres paramètres ont déjà des valeurs par défaut dans app/config.py.

MISTRAL_API_KEY=your_mistral_api_key

# Optionnel : protège /rebuild si l'API est exposée hors usage local.
# API_REBUILD_TOKEN=change_me

# Optionnel : exemples d'overrides ponctuels.
# APP_PORT=8000
# EVENTS_LOCATION=Paris
# LLM_PROVIDER=mistral
# EMBEDDING_PROVIDER=mistral
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_CHAT_MODEL=qwen2.5:7b
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_MIN_TOKENS=600
# OLLAMA_NUM_CTX=8192
# TOP_K=3
# RETRIEVAL_MAX_SCORE=0.45
# LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=600
