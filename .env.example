APP_ENV=local
APP_NAME=Projet 7 - POC RAG
APP_HOST=127.0.0.1
APP_PORT=8000

MISTRAL_API_KEY=your_mistral_api_key
MISTRAL_EMBEDDING_MODEL=mistral-embed
MISTRAL_CHAT_MODEL=mistral-small-latest
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=600
EMBEDDING_BATCH_SIZE=64
EMBEDDING_BATCH_DELAY_SECONDS=1
EMBEDDING_MAX_RETRIES=5
EMBEDDING_RETRY_SLEEP_SECONDS=10

OPENDATASOFT_RECORDS_URL=https://public.opendatasoft.com/api/explore/v2.1/catalog/datasets/evenements-publics-openagenda/records
EVENTS_LOCATION=Paris
EVENTS_LOOKBACK_DAYS=365
EVENTS_LOOKAHEAD_DAYS=90
EVENTS_PAGE_SIZE=100
REQUEST_TIMEOUT_SECONDS=30

DATA_DIR=./data
RAW_DATA_DIR=./data/raw
INTERIM_DATA_DIR=./data/interim
PROCESSED_DATA_DIR=./data/processed
VECTOR_STORE_DIR=./data/vector_store
EVALUATION_DATA_DIR=./data/evaluation

TOP_K=5
CHUNK_SIZE=800
CHUNK_OVERLAP=100
